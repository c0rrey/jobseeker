# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Adzuna (required for job listings) ---
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# --- Crunchbase and supporting APIs have no free tier, enabled only if you have access ---
CRUNCHBASE_ENABLED=false

# --- RapidAPI (required for LinkedIn job search) ---
RAPIDAPI_KEY=your_rapidapi_key_here

# --- SerpAPI (required for company discovery) ---
SERPAPI_KEY=your_serpapi_key_here

# --- Crunchbase (required for company funding data) ---
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# --- Database (optional; defaults to data/jobs.db relative to project root) ---
# DB_PATH=/absolute/path/to/jobs.db
